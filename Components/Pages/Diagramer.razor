@page "/diagramer"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web

<div class="diagramer-container">
    <!-- Left Panel with Tools -->
    <div class="left-panel">
        <!-- Table Tools Section -->
        <div class="panel-section">
            <h3>Tables</h3>
            <button class="btn btn-primary btn-block" @onclick="AddTableViaButton">
                <span class="icon">➕</span> Add Table
            </button>

            <div class="drag-item" draggable="true" @ondragstart="OnDragStartTable">
                <span class="icon">📋</span> Drag Table
            </div>
        </div>

        <!-- Relations Tools Section -->
        <div class="panel-section">
            <h3>Relations</h3>
            <div class="drag-item" draggable="true" @ondragstart="OnDragStartRelation">
                <span class="icon">🔗</span> Drag Relation
            </div>
        </div>

        <!-- JSON Export Section -->
        <div class="panel-section json-section">
            <h3>JSON Schema</h3>
            <div class="json-output">
                <pre>@JsonOutput</pre>
            </div>
            <button class="btn btn-secondary btn-sm" @onclick="CopyJsonToClipboard">Copy JSON</button>
        </div>
    </div>

    <!-- Main Canvas Area -->
    <div class="canvas-area" 
         @ondrop="OnCanvasDrop" 
         @ondragover="OnCanvasDragOver"
         @onmousemove="OnCanvasMouseMove"
         @onmouseup="OnCanvasMouseUp"
         @onmouseleave="OnCanvasMouseUp">

        <!-- Tables Container -->
        <div class="tables-container">
            @foreach (var table in Tables)
            {
                <div class="table-wrapper" 
                     style="position: absolute; left: @(table.X)px; top: @(table.Y)px; width: @(table.Width)px; height: @(table.Height)px; touch-action: none;">

                    <!-- Table Card -->
                    <div class="table-card" data-table-id="@table.Id" style="width: 100%; height: 100%; display: flex; flex-direction: column;">
                        <!-- Table Header with Title Edit -->
                        <div class="table-header" @onmousedown="(args) => OnTableMouseDown(table, args)" style="cursor: move;">
                            @if (EditingTableId == table.Id)
                            {
                                <input type="text" 
                                       class="table-title-input" 
                                       @bind="table.Name"
                                       @onblur="() => EditingTableId = null"
                                       @onkeyup="(args) => HandleTitleKeyUp(args, table)"
                                       autofocus />
                            }
                            else
                            {
                                <h4 class="table-title" @ondblclick="() => EditingTableId = table.Id">
                                    @table.Name
                                </h4>
                            }
                            <button class="close-btn" @onclick="() => RemoveTable(table.Id)">✕</button>
                        </div>

                        <!-- Table Columns -->
                        <div class="table-columns" style="flex: 1; overflow-y: auto;">
                            <!-- Default Column (Fixed) -->
                            <div class="table-row fixed-row">
                                <div class="cell" data-column="name">Name</div>
                                <div class="cell" data-column="datatype">Datatype</div>
                                <div class="cell" data-column="default">Default value</div>
                                <div class="cell" data-column="pk">PK(1,1)</div>
                            </div>

                            <!-- Data Rows -->
                            @foreach (var (row, rowIndex) in table.Rows.Select((r, i) => (r, i)))
                            {
                                <div class="table-row data-row @(SelectedRowIndex == rowIndex && SelectedTableId == table.Id ? "selected-row" : "")" 
                                     @onclick="() => SelectRow(table.Id, rowIndex)">
                                    <div class="cell-wrapper">
                                        <input type="text" 
                                               class="cell-input" 
                                               @bind="row.Name"
                                               @bind:event="oninput"
                                               @onchange="UpdateJsonOutput"
                                               placeholder="Column name" />
                                        <div class="relation-handle" 
                                             @ondragstart="args => OnDragStartCellRelation(args, table.Id, rowIndex)"
                                             draggable="true"
                                             title="Drag to create relation">●</div>
                                    </div>
                                    <input type="text" 
                                           class="cell-input" 
                                           @bind="row.DataType"
                                           @bind:event="oninput"
                                           @onchange="UpdateJsonOutput"
                                           placeholder="DataType" />
                                    <input type="text" 
                                           class="cell-input" 
                                           @bind="row.DefaultValue"
                                           @bind:event="oninput"
                                           @onchange="UpdateJsonOutput"
                                           placeholder="Default" />
                                    <input type="text" 
                                           class="cell-input" 
                                           @bind="row.PrimaryKey"
                                           @bind:event="oninput"
                                           @onchange="UpdateJsonOutput"
                                           placeholder="PK" />
                                    <button class="delete-row-btn" @onclick="() => RemoveRow(table.Id, rowIndex)">✕</button>
                                </div>
                            }
                        </div>

                        <!-- Add Row Button -->
                        <button class="add-row-btn" @onclick="() => AddRow(table.Id)">+ Add Column</button>

                        <!-- Row Order Controls -->
                        @if (table.Rows.Count > 0 && SelectedTableId == table.Id && SelectedRowIndex >= 0)
                        {
                            <div class="row-controls">
                                <button class="order-btn" @onclick="() => MoveRowUp(table.Id)" disabled="@(SelectedRowIndex <= 0)" title="Move row up">▲</button>
                                <button class="order-btn" @onclick="() => MoveRowDown(table.Id)" disabled="@(SelectedRowIndex >= table.Rows.Count - 1)" title="Move row down">▼</button>
                            </div>
                        }

                        <!-- Resize Handle -->
                        <div class="resize-handle" @onmousedown="(args) => OnResizeMouseDown(table, args)"></div>
                    </div>
                </div>
            }
        </div>

        <!-- SVG for Relations -->
        <svg class="relations-svg">
            @foreach (var relation in Relations)
            {
                var fromTable = Tables.FirstOrDefault(t => t.Id == relation.FromTableId);
                var toTable = Tables.FirstOrDefault(t => t.Id == relation.ToTableId);

                @if (fromTable != null && toTable != null)
                {
                    var fromX = fromTable.X + 200;
                    var fromY = fromTable.Y + 100 + (relation.FromRowIndex * 30);
                    var toX = toTable.X + 200;
                    var toY = toTable.Y + 100 + (relation.ToRowIndex * 30);

                    <line x1="@fromX" y1="@fromY" x2="@toX" y2="@toY" class="relation-line" />
                    <circle cx="@fromX" cy="@fromY" r="4" class="relation-point" />
                    <circle cx="@toX" cy="@toY" r="4" class="relation-point" />
                    <g>
                        <text x="@((fromX + toX) / 2)" y="@((fromY + toY) / 2 - 5)" class="relation-label">@relation.Name</text>
                    </g>
                }
            }
        </svg>

        <!-- Drawing Relation Line (Temporary) -->
        @if (DrawingRelation != null)
        {
            <svg class="drawing-svg">
                <line x1="@DrawingRelation.StartX" 
                      y1="@DrawingRelation.StartY" 
                      x2="@DrawingRelation.CurrentX" 
                      y2="@DrawingRelation.CurrentY" 
                      class="drawing-line" />
            </svg>
        }
    </div>
</div>

@code {
    private class TableModel
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Name { get; set; } = "New Table";
        public double X { get; set; } = 50;
        public double Y { get; set; } = 50;
        public double Width { get; set; } = 280;
        public double Height { get; set; } = 400;
        public List<ColumnModel> Rows { get; set; } = new();
    }

    private class ColumnModel
    {
        public string Name { get; set; } = "";
        public string DataType { get; set; } = "";
        public string DefaultValue { get; set; } = "";
        public string PrimaryKey { get; set; } = "";
    }

    private class RelationModel
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string FromTableId { get; set; } = "";
        public int FromRowIndex { get; set; } = 0;
        public string FromColumn { get; set; } = "name";
        public string ToTableId { get; set; } = "";
        public int ToRowIndex { get; set; } = 0;
        public string ToColumn { get; set; } = "name";
        public string Name { get; set; } = "New Relation";
    }

    private class DrawingRelationModel
    {
        public double StartX { get; set; }
        public double StartY { get; set; }
        public double CurrentX { get; set; }
        public double CurrentY { get; set; }
        public string FromTableId { get; set; } = "";
        public int FromRowIndex { get; set; } = 0;
    }

    private List<TableModel> Tables = new();
    private List<RelationModel> Relations = new();
    private string? EditingTableId = null;
    private string DraggedItemType = "";
    private DrawingRelationModel? DrawingRelation = null;
    private TableModel? DraggingTable = null;
    private double DragOffsetX = 0;
    private double DragOffsetY = 0;
    private string JsonOutput = "{}";
    private int SelectedRowIndex = -1;
    private string SelectedTableId = "";
    private TableModel? ResizingTable = null;
    private double ResizeStartX = 0;
    private double ResizeStartY = 0;
    private double ResizeStartWidth = 0;
    private double ResizeStartHeight = 0;

    protected override void OnInitialized()
    {
        UpdateJsonOutput();
    }

    private void AddTableViaButton()
    {
        var newTable = new TableModel
        {
            Name = $"Table_{Tables.Count + 1}",
            X = 400,
            Y = 50
        };
        Tables.Add(newTable);
        UpdateJsonOutput();
    }

    private void OnDragStartTable(DragEventArgs args)
    {
        DraggedItemType = "table";
        args.DataTransfer!.EffectAllowed = "copy";
    }

    private void OnDragStartRelation(DragEventArgs args)
    {
        DraggedItemType = "relation";
        args.DataTransfer!.EffectAllowed = "copy";
    }

    private void OnDragStartCellRelation(DragEventArgs args, string tableId, int rowIndex)
    {
        DrawingRelation = new DrawingRelationModel
        {
            FromTableId = tableId,
            FromRowIndex = rowIndex,
            StartX = args.ClientX,
            StartY = args.ClientY,
            CurrentX = args.ClientX,
            CurrentY = args.ClientY
        };
    }

    private void OnCanvasDragOver(DragEventArgs args)
    {
        args.DataTransfer!.DropEffect = "copy";
    }

    private void OnCanvasMouseMove(MouseEventArgs args)
    {
        if (DraggingTable != null)
        {
            DraggingTable.X = args.ClientX - DragOffsetX;
            DraggingTable.Y = args.ClientY - DragOffsetY;
            StateHasChanged();
        }

        if (ResizingTable != null)
        {
            double deltaX = args.ClientX - ResizeStartX;
            double deltaY = args.ClientY - ResizeStartY;

            ResizingTable.Width = Math.Max(200, ResizeStartWidth + deltaX);
            ResizingTable.Height = Math.Max(300, ResizeStartHeight + deltaY);
            StateHasChanged();
        }
    }

    private void OnCanvasMouseUp()
    {
        DraggingTable = null;
        ResizingTable = null;
    }

    private void OnCanvasDrop(DragEventArgs args)
    {
        if (DraggedItemType == "table")
        {
            var newTable = new TableModel
            {
                Name = $"Table_{Tables.Count + 1}",
                X = args.ClientX - 100,
                Y = args.ClientY - 50
            };
            Tables.Add(newTable);
            UpdateJsonOutput();
            DraggedItemType = "";
        }
    }

    private void OnTableMouseDown(TableModel table, MouseEventArgs args)
    {
        DraggingTable = table;
        DragOffsetX = args.ClientX - table.X;
        DragOffsetY = args.ClientY - table.Y;
    }

    private void OnTableMouseMove(MouseEventArgs args)
    {
        if (DraggingTable != null)
        {
            DraggingTable.X = args.ClientX - DragOffsetX;
            DraggingTable.Y = args.ClientY - DragOffsetY;
            StateHasChanged();
        }
    }

    private void OnTableMouseUp()
    {
        DraggingTable = null;
    }

    private void OnResizeMouseDown(TableModel table, MouseEventArgs args)
    {
        ResizingTable = table;
        ResizeStartX = args.ClientX;
        ResizeStartY = args.ClientY;
        ResizeStartWidth = table.Width;
        ResizeStartHeight = table.Height;
    }

    private void AddRow(string tableId)
    {
        var table = Tables.FirstOrDefault(t => t.Id == tableId);
        if (table != null)
        {
            table.Rows.Add(new ColumnModel());
            UpdateJsonOutput();
        }
    }

    private void RemoveRow(string tableId, int rowIndex)
    {
        var table = Tables.FirstOrDefault(t => t.Id == tableId);
        if (table != null && rowIndex >= 0 && rowIndex < table.Rows.Count)
        {
            table.Rows.RemoveAt(rowIndex);
            if (SelectedTableId == tableId && SelectedRowIndex == rowIndex)
            {
                SelectedRowIndex = -1;
                SelectedTableId = "";
            }
            UpdateJsonOutput();
        }
    }

    private void SelectRow(string tableId, int rowIndex)
    {
        if (SelectedTableId == tableId && SelectedRowIndex == rowIndex)
        {
            SelectedRowIndex = -1;
            SelectedTableId = "";
        }
        else
        {
            SelectedTableId = tableId;
            SelectedRowIndex = rowIndex;
        }
    }

    private void MoveRowUp(string tableId)
    {
        var table = Tables.FirstOrDefault(t => t.Id == tableId);
        if (table != null && SelectedRowIndex > 0 && SelectedRowIndex < table.Rows.Count)
        {
            var temp = table.Rows[SelectedRowIndex];
            table.Rows[SelectedRowIndex] = table.Rows[SelectedRowIndex - 1];
            table.Rows[SelectedRowIndex - 1] = temp;
            SelectedRowIndex--;
            UpdateJsonOutput();
        }
    }

    private void MoveRowDown(string tableId)
    {
        var table = Tables.FirstOrDefault(t => t.Id == tableId);
        if (table != null && SelectedRowIndex >= 0 && SelectedRowIndex < table.Rows.Count - 1)
        {
            var temp = table.Rows[SelectedRowIndex];
            table.Rows[SelectedRowIndex] = table.Rows[SelectedRowIndex + 1];
            table.Rows[SelectedRowIndex + 1] = temp;
            SelectedRowIndex++;
            UpdateJsonOutput();
        }
    }

    private void RemoveTable(string tableId)
    {
        Tables.RemoveAll(t => t.Id == tableId);
        Relations.RemoveAll(r => r.FromTableId == tableId || r.ToTableId == tableId);
        UpdateJsonOutput();
    }

    private void HandleTitleKeyUp(KeyboardEventArgs args, TableModel table)
    {
        if (args.Key == "Enter")
        {
            EditingTableId = null;
            UpdateJsonOutput();
        }
    }

    private void UpdateJsonOutput()
    {
        var schema = new
        {
            tables = Tables.Select(t => new
            {
                id = t.Id,
                name = t.Name,
                position = new { x = t.X, y = t.Y },
                size = new { width = t.Width, height = t.Height },
                columns = t.Rows.Select(r => new
                {
                    name = r.Name,
                    dataType = r.DataType,
                    defaultValue = r.DefaultValue,
                    primaryKey = r.PrimaryKey
                }).ToList()
            }).ToList(),
            relations = Relations.Select(r => new
            {
                id = r.Id,
                name = r.Name,
                fromTable = r.FromTableId,
                fromColumn = r.FromRowIndex,
                toTable = r.ToTableId,
                toColumn = r.ToRowIndex
            }).ToList()
        };

        var options = new JsonSerializerOptions
        {
            WriteIndented = true,
            DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
        };

        JsonOutput = JsonSerializer.Serialize(schema, options);
    }

    private void CopyJsonToClipboard()
    {
        // This would be handled by JavaScript interop in a real implementation
    }
}

<style>
