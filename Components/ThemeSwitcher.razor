@using DiagramER.Services
@rendermode InteractiveServer
@inject ThemeService ThemeService
@implements IAsyncDisposable

<div class="theme-switcher d-flex align-items-center gap-2">
    <div class="btn-group" role="group">
        <input type="radio" class="btn-check" name="theme" id="theme-light" 
               value="light" @onchange="OnLightTheme" disabled="@(!IsConnected)"
               checked="@(CurrentTheme == "light")" />
        <label class="btn btn-outline-secondary btn-sm" for="theme-light" title="Light theme">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-sun-fill" viewBox="0 0 16 16">
                <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708" />
            </svg>
        </label>

        <input type="radio" class="btn-check" name="theme" id="theme-auto"
               value="auto" @onchange="OnAutoTheme" disabled="@(!IsConnected)"
               checked="@(CurrentTheme == "auto")" />
        <label class="btn btn-outline-secondary btn-sm" for="theme-auto" title="Auto theme">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-circle-half" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 0 8 1zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16" />
            </svg>
        </label>

        <input type="radio" class="btn-check" name="theme" id="theme-dark"
               value="dark" @onchange="OnDarkTheme" disabled="@(!IsConnected)"
               checked="@(CurrentTheme == "dark")" />
        <label class="btn btn-outline-secondary btn-sm" for="theme-dark" title="Dark theme">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-moon-stars-fill" viewBox="0 0 16 16">
                <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278" />
                <path d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.73 1.73 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162A1.73 1.73 0 0 0 9.31 6.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.73 1.73 0 0 0 1.097-1.097zM13.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.16 1.16 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.16 1.16 0 0 0-.732-.732l-.774-.258a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z" />
            </svg>
        </label>
    </div>
</div>

@code {
    private string CurrentTheme = "auto";
    private bool IsConnected = true;
    private bool IsDisposed = false;
    private bool _initialized = false;

    protected override async Task OnInitializedAsync()
    {
        ThemeService.OnThemeChanged += HandleThemeRefresh;
        CurrentTheme = ThemeService.GetCurrentTheme();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        _initialized = true;

        try
        {
            await ThemeService.InitializeAsync();
            CurrentTheme = ThemeService.GetCurrentTheme();
            IsConnected = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            IsConnected = false;
        }
    }

    private async Task HandleThemeChange(string theme)
    {
        if (!IsConnected || IsDisposed)
            return;

        try
        {
            CurrentTheme = theme;
            await ThemeService.SetThemeAsync(theme);
        }
        catch
        {
            IsConnected = false;
        }
    }

    private async Task OnLightTheme(ChangeEventArgs e) => await HandleThemeChange("light");

    private async Task OnAutoTheme(ChangeEventArgs e) => await HandleThemeChange("auto");

    private async Task OnDarkTheme(ChangeEventArgs e) => await HandleThemeChange("dark");

    private void HandleThemeRefresh()
    {
        if (!IsDisposed)
        {
            CurrentTheme = ThemeService.GetCurrentTheme();
            StateHasChanged();
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (IsDisposed)
            return;

        IsDisposed = true;
        IsConnected = false;

        try
        {
            ThemeService.OnThemeChanged -= HandleThemeRefresh;
            await ThemeService.DisposeAsync();
        }
        catch
        {
            // Suppress errors during disposal
        }
    }
}

<style>
    .theme-switcher {
        margin-left: auto;
        margin-right: 1rem;
    }

    .theme-label {
        font-size: 1.2rem;
        opacity: 0.8;
    }

    .btn-group .btn-check:checked + label {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }

    .btn-group .btn {
        border-radius: 4px;
        padding: 0.4rem 0.6rem;
        font-size: 0.95rem;
    }

    .theme-switcher :deep(.bi) {
        width: 1rem;
        height: 1rem;
    }
</style>




